{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trello-action-success",
  "title": "TrelloActionSuccessContract",
  "type": "object",
  "required": ["data"],
  "properties": {
    "data": {
      "type": "object",
      "required": ["list"],
      "properties": {
        "list": {
          "type": "object",
          "required": ["id", "name"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[a-f0-9]{24}$"
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            }
          },
          "additionalProperties": true
        },
        "board": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[a-f0-9]{24}$"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
