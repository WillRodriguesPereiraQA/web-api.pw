# Copie para .env e ajuste conforme o ambiente
# cp .env.example .env

# Perfil de ambiente: dev | staging | production | ci
CYPRESS_ENV=dev

# ===== URLs (sobrescrevem o perfil acima) =====
WEB_BASE_URL=https://www.automationexercise.com/
API_BASE_URL=https://api.trello.com/1

# ===== API Trello (opcional — necessário para endpoints autenticados) =====
TRELLO_API_KEY=
TRELLO_API_TOKEN=

# ===== Cypress (opcional) =====
# CYPRESS_HEADLESS=false

# ===== CI/CD =====
# CI=true
