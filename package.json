{
  "name": "web-api.cy",
  "version": "1.0.0",
  "description": "Automação de testes web e API com Cypress, BDD/Cucumber e CI/CD via GitHub Actions",
  "private": true,
  "main": "cypress.config.js",
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:run && npm run report:generate",
    "test:run": "cypress run",
    "test:web": "cypress run --spec \"cypress/e2e/web/**/*.feature\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:watch": "cypress open",
    "test:dev": "cross-env CYPRESS_ENV=dev cypress run",
    "test:staging": "cross-env CYPRESS_ENV=staging cypress run",
    "test:production": "cross-env CYPRESS_ENV=production cypress run",
    "report:generate": "node cucumber-html-report.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "validate": "npm run lint && npm run format:check",
    "ci": "npm run validate && npm run test:all",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillRodriguesPereiraQA/web-api.cy.git"
  },
  "keywords": [
    "cypress",
    "bdd",
    "cucumber",
    "testing",
    "automation",
    "e2e",
    "api",
    "web",
    "ci-cd"
  ],
  "author": "Will Rodrigues Pereira",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "bugs": {
    "url": "https://github.com/WillRodriguesPereiraQA/web-api.cy/issues"
  },
  "homepage": "https://github.com/WillRodriguesPereiraQA/web-api.cy#readme",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0",
    "@eslint/js": "^8.56.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cross-env": "^7.0.3",
    "cypress": "^15.17.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.28.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^2.15.1",
    "husky": "^8.0.3",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "prettier": "^3.1.1"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/api/**/*.{js,ts}",
      "cypress/e2e/web/**/*.{js,ts}",
      "cypress/e2e/ui/**/*.{js,ts}",
      "cypress/support/step_definitions/**/*.{js,ts}"
    ],
    "json": {
      "enabled": true,
      "output": "cypress/reports/cucumber-report.json"
    }
  }
}
